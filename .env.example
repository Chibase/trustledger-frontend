# Local / demo defaults only — do NOT set NEXT_PUBLIC_DEV_ROLE in Vercel Production
# (it bypasses cookie auth and treats visitors as signed-in).

# NEXT_PUBLIC_DEV_ROLE=client

# Frappe Cloud site (Desk + API) — sole backend host (Interserv retired)
NEXT_PUBLIC_API_BASE_URL=https://app.trustledger.co.za
# Optional override for server-only BFF (defaults to NEXT_PUBLIC_API_BASE_URL)
FRAPPE_BASE_URL=https://app.trustledger.co.za

# Lead capture: Frappe CRM "CRM Lead" (preferred) — API key needs create on CRM Lead
# FRAPPE_API_KEY=
# FRAPPE_API_SECRET=
# LEAD_BACKEND=auto
# FRAPPE_LEAD_DOCTYPE=CRM Lead
# Optional instead of Resource API:
# FRAPPE_LEAD_METHOD=srm_core.api.leads.create_lead

# Public site URL (sitemap, robots, HubSpot pageUri)
NEXT_PUBLIC_SITE_URL=https://trustledger-frontend-pi.vercel.app

# demo (default) | live — live uses /api/frappe BFF + /login/live
NEXT_PUBLIC_DATA_MODE=demo

# Keep true until you want live AI methods via BFF
NEXT_PUBLIC_AI_MOCK=true

# --- Required for production lead capture (assessment + demo gate) ---
# HUBSPOT_PORTAL_ID=146786910
# HUBSPOT_FORM_ID=38d24929-09be-4c22-8a7c-ba625a61b902
# HUBSPOT_REGION=eu1

# --- Platform Operator (sole live control until you lift it) ---
# PLATFORM_OPERATOR_ONLY=0
# PLATFORM_OPERATOR_EMAILS=admin@chibaseconsulting.co.za
# Optional: also block demo /app entry (assessment stays public)
# PLATFORM_OPERATOR_LOCK_PUBLIC=0

# T5 — operator-only Customer/Owner provision tools (default off)
# FRAPPE_OWNER_ISSUANCE=0

# Optional generic webhook (used only when HubSpot env is unset)
# ASSESSMENT_WEBHOOK_URL=https://hooks.example.com/leads

# --- Paystack (Vercel checkout — ADR-019) ---
# PAYSTACK_SECRET_KEY=sk_test_…
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_…
# Amounts in ZAR cents — defaults in code are R5,399 / R14,999
# PAYSTACK_AMOUNT_PRACTITIONER_CENTS=539900
# PAYSTACK_AMOUNT_PROJECT_CENTS=1499900
# PAYSTACK_AMOUNT_INSTITUTIONAL_CENTS=0

# Optional Slack/Discord/Make webhook for quote + payment pings (ADR-020)
# OPS_ALERT_WEBHOOK_URL=https://hooks.example.com/trustledger-ops


# --- Access email verification (live OTP + trial activate link) ---
# Production auto-enables when RESEND_API_KEY is set. Force on/off:
# ACCESS_EMAIL_VERIFICATION=1
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=TrustLedger <onboarding@trustledger.co.za>

# --- Form spam protection (required for public launch traffic) ---
# Google reCAPTCHA v3 — domains: trustledger-frontend-pi.vercel.app, trustledger.co.za, localhost
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=
# RECAPTCHA_MIN_SCORE=0.5
# FORM_REQUIRE_RECAPTCHA=1
