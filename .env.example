# Local / demo defaults only — do NOT set NEXT_PUBLIC_DEV_ROLE in Vercel Production
# (it bypasses cookie auth and treats visitors as signed-in).

# NEXT_PUBLIC_DEV_ROLE=client

# Interserv Frappe site (also used server-side by the live auth BFF)
NEXT_PUBLIC_API_BASE_URL=https://app.trustledger.co.za
# Optional override for server-only BFF (defaults to NEXT_PUBLIC_API_BASE_URL)
# FRAPPE_BASE_URL=https://app.trustledger.co.za

# Public site URL (sitemap, robots, HubSpot pageUri)
NEXT_PUBLIC_SITE_URL=https://trustledger-frontend-pi.vercel.app

# demo (default) | live — live uses /api/frappe BFF + /login/live
NEXT_PUBLIC_DATA_MODE=demo

# Keep true until you want live AI methods via BFF
NEXT_PUBLIC_AI_MOCK=true

# --- Required for production lead capture (assessment + demo gate) ---
# HUBSPOT_PORTAL_ID=146786910
# HUBSPOT_FORM_ID=38d24929-09be-4c22-8a7c-ba625a61b902
# HUBSPOT_REGION=eu1

# --- Platform Operator (sole live control until you lift it) ---
# PLATFORM_OPERATOR_ONLY=1
# PLATFORM_OPERATOR_EMAILS=admin@chibaseconsulting.co.za
# Optional: also block demo /app entry (assessment stays public)
# PLATFORM_OPERATOR_LOCK_PUBLIC=0

# Optional generic webhook (used only when HubSpot env is unset)
# ASSESSMENT_WEBHOOK_URL=https://hooks.example.com/leads
